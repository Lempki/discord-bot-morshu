# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required
DISCORD_TOKEN=your-token-here

# Optional (defaults shown)
# COMMAND_PREFIX=!
# FFMPEG_PATH=        # leave empty to use ffmpeg from system PATH
#                     # install via: winget install ffmpeg  /  brew install ffmpeg  /  apt install ffmpeg
# COGS_TO_LOAD=example,voice,youtube,morshu
# BOT_CHANNEL_ID=     # restrict bot commands to this text channel ID
# AUTO_ROLE_NAME=     # role name to assign automatically on member join
# LOCALE=            # bot message language: "en", "silent" (default), or any key added to localization.py
